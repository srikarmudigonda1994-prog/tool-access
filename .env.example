# Copy this file to .env and fill in your real values.
# Never commit the real .env file to a public repository.

# ---- Visitor's PDF via Brevo (HTTPS email API - works on Render's free tier) ----
# 1. Sign up free at brevo.com
# 2. Settings > Senders, Domains & Dedicated IPs > Senders tab > Add a
#    sender > enter your email > click the confirmation link Brevo
#    emails you. No domain needed.
# 3. SMTP & API > API Keys > Generate a new API key
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=the_email_you_verified_with_brevo

# ---- General ----
# Restrict which website can call this backend once deployed.
ALLOWED_ORIGIN=*
PORT=3000

# Set to "true" to test PDF generation without sending anything for real.
DRY_RUN=true

# Which tools are publicly visible on the site right now.
# Comma-separated tool codes, no spaces needed (spaces are trimmed anyway).
# Valid codes: dueno, prod, manto, fin, compras, oper
# Add a code whenever you're ready to reveal that tool - takes effect
# immediately after saving, no redeploy of the frontend needed.
ENABLED_TOOLS=dueno

# ---- Per-customer access links (admin page + tracking + revocation) ----
# 1. Sign up free at neon.tech (permanent free Postgres, unlike Render's
#    free database which expires after 30 days)
# 2. Create a project, copy the connection string it gives you
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# Password for the admin page (yoursite.com/admin.html) where you create
# customer links, revoke access, and view the access history. Pick
# something only you know - this is the only thing protecting that page.
ADMIN_PASSWORD=choose_a_strong_password_here
